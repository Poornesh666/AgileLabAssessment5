pipeline {
    agent any
    environment {
        DOCKER_IMAGE = 'poornesh666/university-portal'
        DOCKER_TAG = "${BUILD_NUMBER}"
        DOCKER_CREDENTIALS = credentials('dockerhub')
    }
    stages {
        stage('Checkout') {
            steps {
                echo '========== Checking out code =========='
                checkout scm
                echo 'Code checked out successfully'
            }
        }
        stage('Build Docker Image') {
            steps {
                echo '========== Building Docker image =========='
                script {
                    bat 'echo Building image: %DOCKER_IMAGE%:%DOCKER_TAG%'
                    bat 'docker build -t %DOCKER_IMAGE%:%DOCKER_TAG% .'
                    bat 'docker tag %DOCKER_IMAGE%:%DOCKER_TAG% %DOCKER_IMAGE%:latest'
                    bat 'docker images --filter=reference="%DOCKER_IMAGE%:*"'
                }
            }
        }

        stage('Push to Docker Hub') {
            steps {
                echo '========== Pushing image to Docker Hub =========='
                script {
                    bat """
                        echo Logging into Docker Hub...
                        docker login -u %DOCKER_CREDENTIALS_USR% -p %DOCKER_CREDENTIALS_PSW%
                        echo Pushing %DOCKER_IMAGE%:%DOCKER_TAG%...
                        docker push %DOCKER_IMAGE%:%DOCKER_TAG%
                        echo Pushing %DOCKER_IMAGE%:latest...
                        docker push %DOCKER_IMAGE%:latest
                        echo Image pushed successfully
                    """
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                echo '========== Deploying to Kubernetes =========='
                script {
                    // Check if kubectl can connect to cluster
                    def clusterConnected = bat(
                        script: 'kubectl cluster-info',
                        returnStatus: true
                    ) == 0
                    
                    if (clusterConnected) {
                        bat """
                            kubectl set image deployment/html-demo html-demo=%DOCKER_IMAGE%:latest --record
                            kubectl rollout status deployment/html-demo
                        """
                        echo 'Deployment completed successfully'
                    } else {
                        echo 'WARNING: Kubernetes cluster not connected. Skipping K8s deployment.'
                        echo 'Image is available on Docker Hub: %DOCKER_IMAGE%:latest'
                    }
                }
            }
        }

        stage('Verification') {
            steps {
                echo '========== Verifying deployment =========='
                script {
                    def clusterConnected = bat(
                        script: 'kubectl cluster-info',
                        returnStatus: true
                    ) == 0
                    
                    if (clusterConnected) {
                        bat """
                            kubectl get deployment html-demo
                            kubectl get pods -l app=html-demo
                        """
                    } else {
                        echo 'Kubernetes not connected. Verifying Docker image instead...'
                        bat 'docker pull %DOCKER_IMAGE%:latest'
                        echo 'Image verified on Docker Hub'
                    }
                }
            }
        }
    }

    post {
        always {
            echo 'Pipeline execution completed'
        }
        failure {
            echo 'Pipeline failed. Check logs above.'
        }
    }
}
